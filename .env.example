# Polaris RE environment variables
# Copy to .env and populate before running projections.

# Path to directory containing actuarial table CSV files
# (mortality tables, YRT rate tables, etc.)
# Structure expected:
#   $POLARIS_DATA_DIR/mortality_tables/cia_2014_male_ns.csv
#   $POLARIS_DATA_DIR/mortality_tables/soa_vbt_2015_male_ns.csv
#   $POLARIS_DATA_DIR/mortality_tables/cso_2001_male.csv
POLARIS_DATA_DIR=/path/to/your/actuarial_data

# Logging level: DEBUG, INFO, WARNING, ERROR
POLARIS_LOG_LEVEL=INFO
