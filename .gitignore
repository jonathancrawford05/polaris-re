# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# uv
.venv/
# uv.lock IS committed — required for reproducible CI installs and GitHub Actions caching.

# Legacy venv / pip
venv/
env/
*.egg-info/
.eggs/
dist/
build/

# Testing & coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/

# Type checking
.mypy_cache/

# Linting
.ruff_cache/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints
notebooks/output/
!notebooks/output/.gitkeep

# Environment variables (never commit secrets)
.env
!.env.example

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# Data files (actuarial tables, large CSVs) — do not commit
data/
!data/.gitkeep
!data/inputs/
!data/inputs/*.csv
!data/inputs/*.json
!data/configs/
!data/configs/*.json
!data/qa/
!data/qa/*.json
!data/qa/golden_inforce.csv
*.parquet

# Logs
*.log
logs/

# Docker
*.tar
